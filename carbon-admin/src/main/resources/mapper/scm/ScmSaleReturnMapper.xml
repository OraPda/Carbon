<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zhonghui.scm.mapper.ScmSaleReturnMapper">
    
    <resultMap type="ScmSaleReturn" id="ScmSaleReturnResult">
        <result property="id"    column="id"    />
        <result property="returnNo"    column="return_no"    />
        <result property="deliveryId"    column="delivery_id"    />
        <result property="contractId"    column="contract_id"    />
        <result property="customId"    column="custom_id"    />
        <result property="returnDate"    column="return_date"    />
        <result property="returnAmount"    column="return_amount"    />
        <result property="reason"    column="reason"    />
        <result property="status"    column="status"    />
        <result property="remark"    column="remark"    />
        <result property="deliveryNo"    column="delivery_no"    />
        <result property="shipping"    column="shipping"    />
        <result property="contractNumber"    column="contract_number"    />
        <result property="customName"    column="custom_name"    />
        <result property="deliveryDate"    column="delivery_date"    />
    </resultMap>

    <resultMap id="ScmSaleReturnScmSaleReturnItemResult" type="ScmSaleReturn" extends="ScmSaleReturnResult">
        <collection property="scmSaleReturnItemList" notNullColumn="sub_id" javaType="java.util.List" resultMap="ScmSaleReturnItemResult" />
    </resultMap>

    <resultMap type="ScmSaleReturnItem" id="ScmSaleReturnItemResult">
        <result property="id"    column="sub_id"    />
        <result property="returnId"    column="sub_return_id"    />
        <result property="materialId"    column="sub_material_id"    />
        <result property="amount"    column="sub_amount"    />
        <result property="orderQuantity"    column="sub_order_quantity"    />
        <result property="deliveryNum"    column="sub_delivery_num"    />
        <result property="returnNum"    column="sub_return_num"    />
        <result property="note"    column="sub_note"    />
        <result property="materialName"    column="material_name"    />
        <result property="materialModel"    column="material_model"    />
        <result property="materialSpecifications"    column="material_specifications"    />
        <result property="materialUnit"    column="material_unit"    />
    </resultMap>

    <sql id="selectScmSaleReturnVo">
        select a.id, a.return_no, a.delivery_id, a.contract_id, a.custom_id,a.return_date, a.return_amount,
        a.reason, a.status, a.remark,b.delivery_no,b.shipping,c.contract_number,d.custom_name,b.delivery_date
	    from scm_sale_return a
	</sql>

    <select id="selectScmSaleReturnList" parameterType="ScmSaleReturn" resultMap="ScmSaleReturnResult">
        <include refid="selectScmSaleReturnVo"/>
        LEFT JOIN scm_sale_delivery b ON a.delivery_id = b.id
        LEFT JOIN scm_sale_contract c ON a.contract_id = c.id
        LEFT JOIN scm_sale_custom d ON a.custom_id = d.id
        <where>  
            <if test="returnNo != null  and returnNo != ''"> and a.return_no = #{returnNo}</if>
            <if test="params.beginReturnDate != null and params.beginReturnDate != '' and params.endReturnDate != null and params.endReturnDate != ''"> and a.return_date between #{params.beginReturnDate} and #{params.endReturnDate}</if>
            <if test="status != null "> and a.status = #{status}</if>
            <if test="deliveryNo != null and deliveryNo != '' ">and b.delivery_no like concat('%', #{deliveryNo}, '%')</if>
        </where>
    </select>
    
    <select id="selectScmSaleReturnById" parameterType="Long" resultMap="ScmSaleReturnScmSaleReturnItemResult">
        select a.id, a.return_no, a.delivery_id, a.contract_id, a.custom_id, a.return_date, a.return_amount, a.reason, a.status, a.remark,
 b.id as sub_id, b.return_id as sub_return_id, b.material_id as sub_material_id, b.amount as sub_amount,
 b.order_quantity as sub_order_quantity, b.delivery_num as sub_delivery_num, b.return_num as sub_return_num,
 b.note as sub_note,e.delivery_no,e.shipping,c.contract_number,d.custom_name,
    f.material_name,f.material_model,f.material_specifications,f.material_unit
        from scm_sale_return a
        left join scm_sale_return_item b on b.return_id = a.id
        LEFT JOIN scm_sale_delivery e ON a.delivery_id = e.id
        LEFT JOIN scm_sale_contract c ON a.contract_id = c.id
        LEFT JOIN scm_sale_custom d ON a.custom_id = d.id
        left join wms_material f on b.material_id = f.id

        where a.id = #{id}
    </select>
        
    <insert id="insertScmSaleReturn" parameterType="ScmSaleReturn" useGeneratedKeys="true" keyProperty="id">
        insert into scm_sale_return
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="returnNo != null">return_no,</if>
            <if test="deliveryId != null">delivery_id,</if>
            <if test="contractId != null">contract_id,</if>
            <if test="customId != null">custom_id,</if>
            <if test="returnDate != null">return_date,</if>
            <if test="returnAmount != null">return_amount,</if>
            <if test="reason != null">reason,</if>
            <if test="status != null">status,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="returnNo != null">#{returnNo},</if>
            <if test="deliveryId != null">#{deliveryId},</if>
            <if test="contractId != null">#{contractId},</if>
            <if test="customId != null">#{customId},</if>
            <if test="returnDate != null">#{returnDate},</if>
            <if test="returnAmount != null">#{returnAmount},</if>
            <if test="reason != null">#{reason},</if>
            <if test="status != null">#{status},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateScmSaleReturn" parameterType="ScmSaleReturn">
        update scm_sale_return
        <trim prefix="SET" suffixOverrides=",">
            <if test="returnNo != null">return_no = #{returnNo},</if>
            <if test="deliveryId != null">delivery_id = #{deliveryId},</if>
            <if test="contractId != null">contract_id = #{contractId},</if>
            <if test="customId != null">custom_id = #{customId},</if>
            <if test="returnDate != null">return_date = #{returnDate},</if>
            <if test="returnAmount != null">return_amount = #{returnAmount},</if>
            <if test="reason != null">reason = #{reason},</if>
            <if test="status != null">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteScmSaleReturnById" parameterType="Long">
        delete from scm_sale_return where id = #{id}
    </delete>

    <delete id="deleteScmSaleReturnByIds" parameterType="String">
        delete from scm_sale_return where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
    
    <delete id="deleteScmSaleReturnItemByReturnIds" parameterType="String">
        delete from scm_sale_return_item where return_id in 
        <foreach item="returnId" collection="array" open="(" separator="," close=")">
            #{returnId}
        </foreach>
    </delete>

    <delete id="deleteScmSaleReturnItemByReturnId" parameterType="Long">
        delete from scm_sale_return_item where return_id = #{returnId}
    </delete>

    <insert id="batchScmSaleReturnItem">
        insert into scm_sale_return_item( id, return_id, material_id, amount, order_quantity, delivery_num, return_num, note) values
		<foreach item="item" index="index" collection="list" separator=",">
            ( #{item.id}, #{item.returnId}, #{item.materialId}, #{item.amount}, #{item.orderQuantity}, #{item.deliveryNum}, #{item.returnNum}, #{item.note})
        </foreach>
    </insert>
</mapper>