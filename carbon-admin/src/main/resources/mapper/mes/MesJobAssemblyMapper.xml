<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zhonghui.mes.mapper.MesJobAssemblyMapper">
    
    <resultMap type="MesJobAssembly" id="MesJobAssemblyResult">
        <result property="id"    column="id"    />
        <result property="jobName"    column="job_name"    />
        <result property="plannedProductionId"    column="planned_production_id"    />
        <result property="startTime"    column="start_time"    />
        <result property="endTime"    column="end_time"    />
        <result property="quantity"    column="quantity"    />
        <result property="status"    column="status"    />
        <result property="remark"    column="remark"    />
        <result property="serialNo"    column="serial_no"    />
        <result property="planNumber"    column="plan_number"    />
        <result property="materialName"    column="material_name"    />
        <result property="materialModel"    column="material_model"    />
        <result property="materialSpecifications"    column="material_specifications"    />
        <result property="materialUnit"    column="material_unit"    />
    </resultMap>

    <resultMap id="MesJobAssemblyMesJobAssemblyItemResult" type="MesJobAssembly" extends="MesJobAssemblyResult">
        <collection property="mesJobAssemblyItemList" notNullColumn="sub_id" javaType="java.util.List" resultMap="MesJobAssemblyItemResult" />
    </resultMap>

    <resultMap type="MesJobAssemblyItem" id="MesJobAssemblyItemResult">
        <result property="id"    column="sub_id"    />
        <result property="jobId"    column="sub_job_id"    />
        <result property="materialId"    column="sub_material_id"    />
        <result property="usageQuantity"    column="sub_usage_quantity"    />
        <result property="remark"    column="sub_remark"    />
        <result property="serialNo"    column="serial_no"    />
        <result property="planNumber"    column="plan_number"    />
        <result property="subMaterialName"    column="sub_material_name"    />
        <result property="subMaterialModel"    column="sub_material_model"    />
        <result property="subMaterialSpecifications"    column="sub_material_specifications"    />
        <result property="subMaterialUnit"    column="sub_material_unit"    />
    </resultMap>

    <sql id="selectMesJobAssemblyVo">
                select a.id,
				a.job_name,
				a.planned_production_id,
				a.start_time,
				a.end_time,
				a.quantity,
				a.status,
				a.remark,
				b.serial_no,
				c.plan_number,
				d.material_name,
				d.material_model,
				d.material_specifications,
				d.material_unit
				from mes_job_assembly a
    </sql>

    <select id="selectMesJobAssemblyList" parameterType="MesJobAssembly" resultMap="MesJobAssemblyResult">
        <include refid="selectMesJobAssemblyVo"/>
        LEFT JOIN mes_planned_production b ON a.planned_production_id = b.id
        LEFT JOIN mes_production_plan c on b.production_plan_id = c.id
        LEFT JOIN wms_material d on b.material_id = d.id
        <where>  
            <if test="jobName != null  and jobName != ''"> and job_name like concat('%', #{jobName}, '%')</if>
            <if test="params.beginStartTime != null and params.beginStartTime != '' and params.endStartTime != null and params.endStartTime != ''"> and start_time between #{params.beginStartTime} and #{params.endStartTime}</if>
            <if test="params.beginEndTime != null and params.beginEndTime != '' and params.endEndTime != null and params.endEndTime != ''"> and end_time between #{params.beginEndTime} and #{params.endEndTime}</if>
            <if test="status != null "> and status = #{status}</if>
        </where>
    </select>
    
    <select id="selectMesJobAssemblyById" parameterType="Long" resultMap="MesJobAssemblyMesJobAssemblyItemResult">
        select
        a.id,
        a.job_name,
        a.planned_production_id,
        a.start_time, a.end_time,
        a.quantity, a.status, a.remark,
        b.id as sub_id,
        b.job_id as sub_job_id,
        b.material_id as sub_material_id,
        b.usage_quantity as sub_usage_quantity,
        b.remark as sub_remark,
        e.serial_no,
		c.plan_number,
		d.material_name,
		d.material_model,
		d.material_specifications,
		d.material_unit,
        f.material_name as sub_material_name,
		f.material_model as sub_material_model,
		f.material_specifications as sub_material_specifications,
		f.material_unit as sub_material_unit
        from mes_job_assembly a
        left join mes_job_assembly_item b on b.job_id = a.id
        LEFT JOIN mes_planned_production e ON a.planned_production_id = e.id
        LEFT JOIN mes_production_plan c on e.production_plan_id = c.id
        LEFT JOIN wms_material d on e.material_id = d.id
        left join wms_material f on b.material_id = f.id
        where a.id = #{id}
    </select>
        
    <insert id="insertMesJobAssembly" parameterType="MesJobAssembly" useGeneratedKeys="true" keyProperty="id">
        insert into mes_job_assembly
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="jobName != null and jobName != ''">job_name,</if>
            <if test="plannedProductionId != null">planned_production_id,</if>
            <if test="startTime != null">start_time,</if>
            <if test="endTime != null">end_time,</if>
            <if test="quantity != null">quantity,</if>
            <if test="status != null">status,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="jobName != null and jobName != ''">#{jobName},</if>
            <if test="plannedProductionId != null">#{plannedProductionId},</if>
            <if test="startTime != null">#{startTime},</if>
            <if test="endTime != null">#{endTime},</if>
            <if test="quantity != null">#{quantity},</if>
            <if test="status != null">#{status},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateMesJobAssembly" parameterType="MesJobAssembly">
        update mes_job_assembly
        <trim prefix="SET" suffixOverrides=",">
            <if test="jobName != null and jobName != ''">job_name = #{jobName},</if>
            <if test="plannedProductionId != null">planned_production_id = #{plannedProductionId},</if>
            <if test="startTime != null">start_time = #{startTime},</if>
            <if test="endTime != null">end_time = #{endTime},</if>
            <if test="quantity != null">quantity = #{quantity},</if>
            <if test="status != null">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteMesJobAssemblyById" parameterType="Long">
        delete from mes_job_assembly where id = #{id}
    </delete>

    <delete id="deleteMesJobAssemblyByIds" parameterType="String">
        delete from mes_job_assembly where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
    
    <delete id="deleteMesJobAssemblyItemByJobIds" parameterType="String">
        delete from mes_job_assembly_item where job_id in 
        <foreach item="jobId" collection="array" open="(" separator="," close=")">
            #{jobId}
        </foreach>
    </delete>

    <delete id="deleteMesJobAssemblyItemByJobId" parameterType="Long">
        delete from mes_job_assembly_item where job_id = #{jobId}
    </delete>

    <insert id="batchMesJobAssemblyItem">
        insert into mes_job_assembly_item( id, job_id, material_id, usage_quantity, remark) values
		<foreach item="item" index="index" collection="list" separator=",">
            ( #{item.id}, #{item.jobId}, #{item.materialId}, #{item.usageQuantity}, #{item.remark})
        </foreach>
    </insert>
</mapper>